# Tenda Pro — environment variables
# Copy to .env.local and fill in real values. Never commit .env.local.
# -----------------------------------------------------------------------

# ── Supabase ──────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — used for admin/server-side operations (e.g. nightly digest)
# Found in: Supabase dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Postgres Transaction pooler (port 6543; requires ?prepare=false)
# Found in: Supabase dashboard → Project Settings → Database → Connection string → Transaction
DATABASE_URL=postgresql://postgres:[password]@[region].pooler.supabase.com:6543/postgres

# ── Brevo (email / SMTP) ───────────────────────────────────────────────
# Found in: Brevo dashboard → SMTP & API → SMTP
BREVO_SMTP_USER=your-brevo-login-email
BREVO_SMTP_PASS=your-brevo-smtp-password
BREVO_SENDER=noreply@yourdomain.com
BREVO_SENDER_NAME=Tenda Pro

# ── Resend (alternative email — optional) ─────────────────────────────
RESEND_API_KEY=re_...

# ── Anthropic (AI features) ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── PayMongo (payments) ───────────────────────────────────────────────
# Found in: PayMongo dashboard → Developers → API Keys
PAYMONGO_SECRET_KEY=sk_test_...
PAYMONGO_WEBHOOK_SECRET=whsec_...

# ── App ────────────────────────────────────────────────────────────────
# Public URL shown in metadata and Open Graph (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://tenda.ph
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Cron ───────────────────────────────────────────────────────────────
# Secret sent in Authorization: Bearer header by Vercel Cron
CRON_SECRET=your-cron-secret
